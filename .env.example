# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (Project Settings > API > service_role - SECRET, ne jamais
# exposer cote client) - necessaire pour que le proprietaire d'un
# restaurant puisse creer des comptes pour son personnel.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (Project Settings > Database > Connection string)
DATABASE_URL=
DIRECT_URL=

# CinetPay (dashboard.cinetpay.com > Intégration API)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# ElyonPay (choix alternatif a CinetPay en mode caisse) - cle a recuperer
# sur elyonpay.com une fois le compte cree. ELYONPAY_BASE_URL est une
# supposition a verifier avec la vraie documentation (docs.elyonpay.com/fr/)
ELYONPAY_API_KEY=
ELYONPAY_BASE_URL=https://api.elyonpay.com/v1

# UltraMsg (WhatsApp API) - instance déjà utilisée sur SecurEcole
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=

# n8n (si webhook déclenché depuis l'app)
N8N_WEBHOOK_URL=
